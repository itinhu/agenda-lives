# ============================================================
# .env — Variáveis de ambiente do servidor
# NUNCA envie este arquivo para o Git!
# Adicione .env ao seu .gitignore
# ============================================================

# URL do seu projeto Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Service Role Key (somente no backend — NUNCA no frontend!)
# Encontre em: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Senha do painel administrativo (escolha uma senha forte!)
ADMIN_PASSWORD=troque_esta_senha_123

# Porta do servidor (padrão: 3001)
PORT=3001

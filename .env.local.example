# ================================================================
# .env.local  —  Cole este arquivo na raiz do projeto
# Na Vercel: cole cada variável em Settings > Environment Variables
# NUNCA envie este arquivo para o Git (já está no .gitignore)
# ================================================================

# URL do projeto Supabase (aba Settings > API)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Service Role Key — somente no servidor (NUNCA exponha no frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Senha do painel administrativo
ADMIN_PASSWORD=troque_esta_senha_segura
